{
    "name": "wa-map-optimizer-vite",
    "version": "1.2.4",
    "description": "Vite plugin for WA Map Optimizer",
    "main": "dist/index.js",
    "author": "Nolway (Alexis Faizeau)",
    "license": "AGPL-3.0",
    "repository": {
        "type": "git",
        "url": "https://github.com/nolway/wa-map-optimizer-vite"
    },
    "types": "dist/index.d.ts",
    "files": [
        "/dist"
    ],
    "type": "module",
    "scripts": {
        "prepare": "husky install",
        "build": "tsc --build",
        "lint": "eslint .",
        "typecheck": "tsc --noEmit",
        "format": "prettier --ignore-path .gitignore --write \"**/*.+(js|ts|json)\"",
        "test": "npm run build && cd test && npm install && npm run build && npm test"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/node": "^20.11.0",
        "eslint": "^10.0.3",
        "eslint-config-prettier": "^10.1.8",
        "globals": "^17.4.0",
        "husky": ">=6",
        "jiti": "^2.6.1",
        "lint-staged": ">=10",
        "prettier": "^2.8.8",
        "typescript": "^5.4.0",
        "typescript-eslint": "^8.57.0",
        "vite": "^6.0.0"
    },
    "dependencies": {
        "@workadventure/tiled-map-type-guard": "^2.1.2",
        "wa-map-optimizer": "^1.4.8"
    },
    "lint-staged": {
        "*.{js,ts}": [
            "eslint --fix"
        ],
        "*.{js,ts,json}": [
            "prettier --write"
        ]
    }
}
